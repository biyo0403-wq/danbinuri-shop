# 실제 값은 .env.local 에 넣으세요 (.env.local 은 깃에 올라가지 않음)
# Vercel 배포 시에는 Vercel > Project > Settings > Environment Variables 에도 등록해야 함

# Supabase (Project Settings > API)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Resend 이메일 알림 (resend.com > API Keys) — 없으면 메일 없이 DB 저장만 됨
RESEND_API_KEY=re_...
INQUIRY_NOTIFY_EMAIL=danbinuri25@danbinuri.kr
# 보내는 사람(선택) — Resend 에서 도메인 인증 후에만 커스텀 주소 발송 가능
INQUIRY_FROM_EMAIL=단비누리 견적문의 <noreply@danbinuri.kr>
